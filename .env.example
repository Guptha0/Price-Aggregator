# Copy this file to ".env" and fill in real values. Never commit ".env" itself.

# --- Alerting: Discord webhook (leave blank to disable) ---
DISCORD_WEBHOOK_URL=

# --- Alerting: SMTP email (leave blank to disable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Storage backend: "sqlite" or "csv" ---
STORAGE_BACKEND=sqlite

# --- Playwright behavior ---
HEADLESS=true
